{
  "name": "diakem-control-center",
  "version": "0.6.0",
  "private": true,
  "scripts": {
    "build:package": "bash scripts/build-package.sh $(node -p \"require('./package.json').version\")",
    "release": "dotenv -- release-it",
    "release:dry": "dotenv -- release-it --dry-run",
    "prepare": "husky"
  },
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.6",
    "dotenv-cli": "^11.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "latest",
    "release-it": "^19.2.4"
  },
  "dependencies": {
    "sharp": "^0.32.6"
  },
  "lint-staged": {
    "backend/{src,test}/**/*.ts": [
      "oxfmt --write",
      "backend/node_modules/.bin/oxlint --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "oxfmt --write",
      "frontend/node_modules/.bin/oxlint --fix"
    ]
  }
}
