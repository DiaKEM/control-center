{
  "name": "diakem-control-center",
  "version": "0.0.1",
  "private": true,
  "description": "A nightscout frontend on steroids to improve diabetes management with detailed reports and alerts",
  "license": "MIT",
  "author": "Selcuk Kekec <khskekec@gmail.com>",
  "scripts": {
    "build": "nest build",
    "format": "oxfmt --write -c ../.oxfmtrc.json src test",
    "format:check": "oxfmt --check -c ../.oxfmtrc.json src test",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "cli": "ts-node -r tsconfig-paths/register src/cli.ts",
    "cli:prod": "node dist/cli",
    "lint": "oxlint --fix src test",
    "lint:check": "oxlint src test",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:check-nightscout-api": "jest --config ./test/jest-e2e.json --testPathPatterns=nightscout-api --testNamePattern=\"should (connect to Nightscout and return a valid status|fetch at least one recent entry)\"",
    "test:check-pushover-api": "jest --config ./test/jest-e2e.json --testPathPatterns=pushover --testNamePattern=\"should (return true with valid credentials|send a basic message)\"",
    "test:check-telegram-api": "jest --config ./test/jest-e2e.json --testPathPatterns=telegram --testNamePattern=\"should (return true and send a test message with valid credentials|send a plain text message)\""
  },
  "dependencies": {
    "@nestjs/common": "^11.1.17",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/serve-static": "^5.0.4",
    "@nestjs/swagger": "^11.2.6",
    "@types/sharp": "^0.31.1",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "mongoose": "^9.3.0",
    "nest-commander": "^3.20.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.34.5",
    "vega-node": "^0.1.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.7",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^6.0.2",
    "jest": "^30.0.0",
    "oxlint": "latest",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  },
  "jest": {
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "coverageProvider": "v8",
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testEnvironment": "node",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    }
  }
}
