{
  "hooks": {
    "before:bump": [
      "cd frontend && npm run build",
      "cd backend && npm run build"
    ],
    "after:bump": [
      "zip -r frontend-${version}.zip frontend/dist",
      "cd backend && zip -r ../backend-${version}.zip dist package.json package-lock.json -x 'dist/.env'"
    ],
    "after:release": [
      "rm -f frontend-${version}.zip backend-${version}.zip"
    ]
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "skipChecks": true,
    "assets": [
      "frontend-${version}.zip",
      "backend-${version}.zip"
    ]
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  }
}
