{
  "hooks": {
    "before:bump": [],
    "after:bump": [
      "bash scripts/build-package.sh ${version}"
    ],
    "after:release": [
      "rm -f diakem-control-center-${version}.zip"
    ]
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}"
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "skipChecks": true,
    "assets": [
      "diakem-control-center-${version}.zip"
    ]
  },
  "npm": {
    "publish": false
  },
  "plugins": {
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  }
}
